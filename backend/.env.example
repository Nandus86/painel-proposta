# Painel Proposta - Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/painel_proposta
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/painel_proposta

# JWT
SECRET_KEY=super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# App
APP_NAME=Painel Proposta
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:5173
